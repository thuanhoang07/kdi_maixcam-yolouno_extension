<xml xmlns="https://developers.google.com/blockly/xml" id="toolbox" style="display: none">
  <category name="CAMERA RISC-V" colour="#cb2026" icon="camera">
    
    <block type="init_camera_uart"></block>
    
    <block type="get_object_count"></block>
    
    <block type="get_property_by_label">
      <field name="PROPERTY">center_x</field>
      <value name="LABEL">
        <shadow type="text">
          <field name="TEXT">person</field>
        </shadow>
      </value>
    </block>
    
    <block type="get_all_objects"></block>
    
    <block type="get_object_at_index">
      <value name="INDEX">
        <shadow type="math_number">
          <field name="NUM">0</field>
        </shadow>
      </value>
    </block>
    
  </category>
</xml>